    <audio id="musica" loop>
        <!-- SUBSTITUA pelo link do Birds of a Feather -->
        <source src="https://www.soundjay.com/misc/sounds/bell-ringing-05.wav" type="audio/mpeg">
    </audio>

    <script>
        let musicaTocando = false;
        let todasVelasApagadas = false;

        // Confetes
        function criarConfetes() {
            const container = document.getElementById('confetti-container');
            setInterval(() => {
                for(let i = 0; i < 5; i++) {
                    const confetti = document.createElement('div');
                    confetti.className = 'confetti';
                    confetti.style.left = Math.random() * 100 + 'vw';
                    confetti.style.animationDuration = (Math.random() * 3 + 2) + 's';
                    container.appendChild(confetti);
                    setTimeout(() => confetti.remove(), 5000);
                }
            }, 300);
        }

        // Música (use um link direto do YouTube ou arquivo)
        function toggleMusica() {
            const audio = document.getElementById('musica');
            if (musicaTocando) {
                audio.pause();
                musicaTocando = false;
            } else {
                audio.play().catch(e => alert('Toque manualmente a música "Birds of a Feather" no YouTube! 🎵'));
                musicaTocando = true;
            }
        }

        // Soprar velas
        function soprarVelas() {
            if (todasVelasApagadas) {
                alert('🎉 Todas as velas já foram apagadas! Parabéns! 🥳');
                return;
            }

            const velas = document.querySelectorAll('.vela');
            const velaAleatoria = Math.floor(Math.random() * velas.length);
            velas[velaAleatoria].classList.add('vela-apagada');
            
            // Efeito de fumaça
            criarFumaca(velas[velaAleatoria]);

            if (document.querySelectorAll('.vela:not(.vela-apagada)').length === 0) {
                todasVelasApagadas = true;
                document.querySelector('.soprar-btn').innerHTML = '🎉 PARABÉNS! 🥳🥳🥳';
                criarConfetes();
            }
        }

        function criarFumaca(vela) {
            const fumaca = document.createElement('div');
            fumaca.style.cssText = `
                position: absolute; top: -20px; left: 50%; 
                width: 20px; height: 20px; 
                background: rgba(200,200,200,0.7); 
                border-radius: 50%; 
                transform: translateX(-50%);
                animation: fumaca 2s ease-out forwards;
                pointer-events: none;
                z-index: 100;
            `;
            vela.appendChild(fumaca);
            
            setTimeout(() => fumaca.remove(), 2000);
        }

        // Zoom nas fotos
        function zoomFoto(img) {
            img.style.transform = 'scale(1.5) rotate(5deg)';
            setTimeout(() => {
                img.style.transform = 'scale(1) rotate(0deg)';
            }, 1000);
        }

        // Iniciar confetes
        criarConfetes();

        // Detectar sopro do microfone
        if (navigator.mediaDevices && navigator.mediaDevices.getUserMedia) {
            navigator.mediaDevices.getUserMedia({ audio: true }).then(stream => {
                const audioContext = new AudioContext();
                const analyser = audioContext.createAnalyser();
                const microphone = audioContext.createMediaStreamSource(stream);
                microphone.connect(analyser);
                
                const dataArray = new Uint8Array(analyser.frequencyBinCount);
                
                function detectarSopro() {
                    analyser.getByteFrequencyData(dataArray);
                    const volume = dataArray.reduce((a, b) => a + b) / dataArray.length;
                    if (volume > 50) {
                        soprarVelas();
                    }
                    requestAnimationFrame(detectarSopro);
                }
                detectarSopro();
            }).catch(() => {});
        }
    </script>
</body>

    <style>
        @import url('https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600;700&display=swap');
        
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Poppins', sans-serif;
            background: linear-gradient(45deg, #ff6b6b, #4ecdc4, #45b7d1, #96ceb4, #feca57);
            background-size: 400% 400%;
            animation: gradientShift 15s ease infinite;
            min-height: 100vh;
            overflow-x: hidden;
            position: relative;
        }

        @keyframes gradientShift {
            0% { background-position: 0% 50%; }
            50% { background-position: 100% 50%; }
            100% { background-position: 0% 50%; }
        }

        /* Partículas de confete */
        .confetti {
            position: fixed;
            width: 10px;
            height: 10px;
            background: #ff6b6b;
            animation: confetti-fall 3s linear infinite;
            pointer-events: none;
            z-index: 1000;
        }

        .confetti:nth-child(odd) { background: #4ecdc4; animation-delay: 0.5s; }
        .confetti:nth-child(even) { background: #feca57; animation-delay: 1s; }
        .confetti:nth-child(3n) { background: #45b7d1; animation-delay: 1.5s; }

        @keyframes confetti-fall {
            0% { transform: translateY(-100vh) rotate(0deg); opacity: 1; }
            100% { transform: translateY(100vh) rotate(720deg); opacity: 0; }
        }

        .container {
            max-width: 900px;
            margin: 0 auto;
            padding: 20px;
            position: relative;
            z-index: 10;
        }

        .header {
            text-align: center;
            margin-bottom: 40px;
        }

        .idade {
            font-size: 4rem;
            font-weight: 700;
            background: linear-gradient(45deg, #ff6b6b, #4ecdc4);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            margin-bottom: 20px;
            animation: pulse 2s infinite;
            text-shadow: 0 0 30px rgba(255,255,255,0.5);
        }

        @keyframes pulse {
            0%, 100% { transform: scale(1); }
            50% { transform: scale(1.05); }
        }

        h1 {
            font-size: 3rem;
            color: white;
            text-shadow: 0 10px 30px rgba(0,0,0,0.3);
            margin-bottom: 10px;
        }

        .music-btn {
            background: rgba(255,255,255,0.2);
            border: 2px solid white;
            color: white;
            padding: 15px 30px;
            font-size: 1.2rem;
            border-radius: 50px;
            cursor: pointer;
            transition: all 0.3s;
            backdrop-filter: blur(10px);
            margin: 20px auto;
            display: block;
        }

        .music-btn:hover {
            background: white;
            color: #ff6b6b;
            transform: scale(1.05);
        }

        .bolo-container {
            text-align: center;
            margin: 60px 0;
            perspective: 1000px;
        }

        .bolo {
            display: inline-block;
            position: relative;
            transform-style: preserve-3d;
        }

        .bolo-base {
            width: 200px;
            height: 120px;
            background: linear-gradient(45deg, #d4a574, #c68642);
            border-radius: 100px 100px 20px 20px;
            margin: 0 auto 20px;
            box-shadow: 0 20px 40px rgba(0,0,0,0.3);
            position: relative;
        }

        .velas {
            display: flex;
            justify-content: space-around;
            position: absolute;
            top: -30px;
            left: 50%;
            transform: translateX(-50%);
        }

        .vela {
            width: 8px;
            height: 40px;
            background: linear-gradient(to top, #f4e4bc, #fff);
            border-radius: 4px 4px 0 0;
            position: relative;
            animation: velaChama 2s infinite alternate;
        }

        .chama {
            width: 12px;
            height: 20px;
            background: radial-gradient(circle, #ffeb3b, #ff9800, #f44336);
            border-radius: 50% 50% 50% 50% / 60% 60% 40% 40%;
            position: absolute;
            top: -15px;
            left: 50%;
            transform: translateX(-50%);
            box-shadow: 0 0 10px #ffeb3b;
            animation: chamaDanca 0.5s infinite alternate;
        }

        @keyframes velaChama {
            0% { box-shadow: 0 0 5px rgba(255,255,255,0.5); }
            100% { box-shadow: 0 0 20px rgba(255,255,255,0.8); }
        }

        @keyframes chamaDanca {
            0% { transform: translateX(-50%) translateY(0) rotate(-2deg); }
            100% { transform: translateX(-50%) translateY(-2px) rotate(2deg); }
        }

        .soprar-btn {
            background: linear-gradient(45deg, #ff6b6b, #ff8e8e);
            color: white;
            border: none;
            padding: 20px 40px;
            font-size: 1.5rem;
            border-radius: 50px;
            cursor: pointer;
            margin-top: 30px;
            font-weight: 600;
            transition: all 0.3s;
            box-shadow: 0 10px 30px rgba(255,107,107,0.4);
        }

        .soprar-btn:hover {
            transform: scale(1.1);
            box-shadow: 0 15px 40px rgba(255,107,107,0.6);
        }

        .vela-apagada .chama {
            opacity: 0 !important;
            animation: none !important;
        }

        .texto {
            background: rgba(255,255,255,0.95);
            padding: 40px;
            border-radius: 25px;
            margin: 40px 0;
            box-shadow: 0 20px 60px rgba(0,0,0,0.2);
            backdrop-filter: blur(10px);
            line-height: 1.8;
            font-size: 1.2rem;
            color: #333;
            max-width: 800px;
            margin-left: auto;
            margin-right: auto;
        }

        .fotos {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 20px;
            margin: 40px 0;
        }

        .foto {
            width: 100%;
            height: 250px;
            object-fit: cover;
            border-radius: 20px;
            box-shadow: 0 15px 40px rgba(0,0,0,0.3);
            transition: transform 0.3s;
            cursor: pointer;
        }

        .foto:hover {
            transform: scale(1.05) rotate(2deg);
        }

        .extras {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 20px;
            margin: 40px 0;
            text-align: center;
        }

        .extra-card {
            background: rgba(255,255,255,0.9);
            padding: 30px;
            border-radius: 20px;
            box-shadow: 0 15px 40px rgba(0,0,0,0.2);
            backdrop-filter: blur(10px);
            transition: transform 0.3s;
        }

        .extra-card:hover {
            transform: translateY(-10px);
        }

        .coracao {
            font-size: 4rem;
            animation: batimento 1.5s infinite;
            display: block;
            margin-bottom: 10px;
        }

        @keyframes batimento {
            0%, 100% { transform: scale(1); }
            50% { transform: scale(1.2); }
        }

        .final {
            text-align: center;
            font-size: 2rem;
            color: white;
            margin-top: 40px;
            text-shadow: 0 5px 20px rgba(0,0,0,0.5);
            animation: bounce 2s infinite;
        }

        @keyframes bounce {
            0%, 20%, 50%, 80%, 100% { transform: translateY(0); }
            40% { transform: translateY(-10px); }
            60% { transform: translateY(-5px); }
        }

        @media (max-width: 768px) {
            .idade { font-size: 3rem; }
            h1 { font-size: 2rem; }
            .texto { padding: 20px; font-size: 1rem; }
        }
    </style>
</head>
<body>
    <!-- Partículas de confete -->
    <div id="confetti-container"></div>

    <div class="container">
        <div class="header">
            <div class="idade">19 🎉</div>
            <h1>Feliz Aniversário, Fedido! 😂💙</h1>
            <button class="music-btn" onclick="toggleMusica()">
                🎵 Birds of a Feather 💙
            </button>
        </div>

        <div class="bolo-container">
            <div class="bolo">
                <div class="bolo-base"></div>
                <div class="velas" id="velas">
                    <div class="vela" data-vela="1"><div class="chama"></div></div>
